{
  "Template": {
    "prefix": "temp",
    "body": [
      "//!*script",
        "/**",
        " * discription",
        " *",
        " * PPx.Arguments(",
        " * 0:",
        " * )",
        " */",
        "\n'use strict';"
    ]
  },
  "Comment": {
    "prefix": "come",
    "body": [
      "\/**",
      " * $1",
      " *\/"
    ]
  },
  "Object inline": {
    "prefix": "obji",
    "body": "'$1': '$2',\n$0"
  },
  "Object arrow function": {
    "prefix": "objaf",
    "body": "'$1': ('$2') =>$3,\n$0"
  },
  "Object function": {
    "prefix": "obji",
    "body": "'$1': function ('$2') {$3},\n$0"
  },
  "If": {
    "prefix": "if",
    "body": [
    "if ($1) {",
      "\t$2",
      "}$3",
      "$0"
    ]
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for (let ${1:i} = 0; ${1:i} < ${2:l}; ${1:i}++) {",
        "\t$3",
        "}",
        "\n$0"
    ]
  },
  "For loop limit": {
    "prefix": "forl",
    "body": [
      "for (let ${1:i} = 0, l = ${2:array}.length; ${1:index} < l; ${1:i}++) {",
      "\tconst ${3:element} = ${2:array}[${1:i}];",
      "\t$0",
      "}"
    ]
  },
  "For loop var": {
    "prefix": "forv",
    "body": [
      "for (var ${1:i} = 0; ${1:i} < ${2:l}; ${1:i}++) {",
        "\t$3",
        "}",
        "\n$0"
    ]
  },
  "For loop var limit": {
    "prefix": "forvl",
    "body": [
      "for (var ${1:i} = 0, ${2:l} = ${3:array}.length; ${1:i} < ${2:l}; ${1:i}++) {",
      "\tvar ${4:element} = ${3:array}[${1:i}];",
      "\t$0",
      "}"
    ]
  },
  "Arrow function": {
    "prefix": "af",
    "body": "($1) => $2"
  },
  "Anonymous arrow function": {
    "prefix": "afn",
    "body": "(($1) => $2)()"
  },
  "Function": {
    "prefix": "func",
    "body": "function ($1) { $2 }"
  },
  "Anonymous function": {
    "prefix": "funcn",
    "body": "(function ($1) { %2 })()"
  },
  "Do loop": {
    "prefix": "do",
    "body": [
      "do{",
        "\t$1",
        "} while($0);"
    ]
  },
}

